<Window x:Class="Numaralandirici.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Numaralandırıcı" Height="600" Width="800"
        MinHeight="450" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Icon="icon.png"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Numaralandırıcı" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <!-- PAGE 1: File List -->
        <Grid Grid.Row="1" x:Name="FileListPage">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Dosyaları aşağıya sürükleyip bırakın veya 'Dosya Ekle' butonunu kullanın."
                       Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,10"/>

            <Border Grid.Row="1" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4"
                    Background="{StaticResource CardBg}" Padding="1">
                <Grid>
                    <StackPanel x:Name="DropZone" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Dosyaları buraya sürükleyin" FontSize="16"
                                   Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock Text="PDF, Word, Excel, Resim, Outlook (.msg)" FontSize="12"
                                   Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>

                    <ListView x:Name="FileList" ItemsSource="{Binding Files}" Background="Transparent">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Sıra" Width="70"
                                                DisplayMemberBinding="{Binding Order.DisplayText}"/>
                                <GridViewColumn Header="Dosya Adı" Width="300"
                                                DisplayMemberBinding="{Binding FileName}"/>
                                <GridViewColumn Header="Tür" Width="80"
                                                DisplayMemberBinding="{Binding FileType}"/>
                                <GridViewColumn Header="Durum" Width="120"
                                                DisplayMemberBinding="{Binding Status}"/>
                                <GridViewColumn Header="" Width="40">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="X" Width="22" Height="22" Padding="0"
                                                    Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Foreground="#CC0000" FontSize="11" FontWeight="Bold"
                                                    ToolTip="Kaldır"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- PAGE 2: Preview Grid -->
        <Grid Grid.Row="1" x:Name="PreviewPage" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Sayfa önizlemesi - birleştirilecek sırayla görüntüleniyorlar."
                       Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,10"/>

            <Border Grid.Row="1" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4"
                    Background="{StaticResource CardBg}" Padding="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Previews}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="6" BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                        CornerRadius="3" Background="{StaticResource CardBg}" Padding="4">
                                    <StackPanel>
                                        <Grid>
                                            <Image Source="{Binding Thumbnail}" Width="130" Stretch="Uniform"
                                                   RenderTransformOrigin="0.5,0.5">
                                                <Image.LayoutTransform>
                                                    <RotateTransform Angle="{Binding Rotation}"/>
                                                </Image.LayoutTransform>
                                            </Image>

                                            <!-- Rotate button (top-left) - always visible -->
                                            <Button Command="{Binding RotateCommand}" CommandParameter="{Binding}"
                                                    Width="24" Height="24" Padding="0"
                                                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2"
                                                    Background="#88FFFFFF" ToolTip="Döndür">
                                                <TextBlock Text="&#x21BB;" FontSize="14" FontWeight="Bold"/>
                                            </Button>

                                            <!-- Magnify button (top-right) - always visible -->
                                            <Button Command="{Binding MagnifyCommand}" CommandParameter="{Binding}"
                                                    Width="24" Height="24" Padding="0"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="2"
                                                    Background="#88FFFFFF" ToolTip="Büyüt">
                                                <TextBlock Text="&#x1F50D;" FontSize="12"/>
                                            </Button>
                                        </Grid>
                                        <TextBlock Text="{Binding Label}" HorizontalAlignment="Center"
                                                   FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- PAGE 3: Summary -->
        <Grid Grid.Row="1" x:Name="SummaryPage" Visibility="Collapsed">
            <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4"
                    Background="{StaticResource CardBg}" Padding="30"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    MinWidth="400">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Numaralandırma Tamamlandı" FontSize="20" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,25"/>

                    <!-- Page count -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12" HorizontalAlignment="Center">
                        <TextBlock Text="Sayfa Sayısı: " FontSize="14" Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock Text="{Binding SummaryPageCount}" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- File size -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5" HorizontalAlignment="Center">
                        <TextBlock Text="Dosya Boyutu: " FontSize="14" Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock x:Name="TxtFileSize" Text="{Binding SummaryFileSize}" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Large file warning -->
                    <TextBlock x:Name="TxtFileSizeWarning" Text="Yüksek dosya boyutu"
                               FontSize="12" Foreground="#CC0000" HorizontalAlignment="Center"
                               Margin="0,0,0,12" Visibility="Collapsed"/>

                    <!-- Separator -->
                    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Margin="0,10,0,20"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Önizle" Command="{Binding PreviewMergedCommand}"
                                Padding="20,8" Margin="0,0,8,0"/>
                        <Button Content="Kaydet" Command="{Binding SaveCommand}"
                                Style="{StaticResource AccentButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,5">
            <!-- Info button (left-aligned) -->
            <Button Content="&#x2139;" ToolTip="Hakkında" Click="BtnInfo_Click"
                    Width="32" Height="32" Padding="0" FontSize="16" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,5" HorizontalAlignment="Right">
            <!-- File list page buttons -->
            <Button x:Name="BtnAddFiles" Content="Dosya Ekle" Command="{Binding AddFilesCommand}"
                    Padding="15,8" Margin="0,0,8,0"/>
            <Button x:Name="BtnClear" Content="Temizle" Command="{Binding ClearCommand}"
                    Padding="15,8" Margin="0,0,8,0"/>
            <Button x:Name="BtnContinue" Content="Devam Et" Command="{Binding ContinueCommand}"
                    Style="{StaticResource AccentButton}"/>

            <!-- Preview page buttons -->
            <Button x:Name="BtnBackPreview" Content="Son" Command="{Binding BackCommand}"
                    Padding="15,8" Margin="0,0,8,0" Visibility="Collapsed"/>
            <Button x:Name="BtnNumarandir" Content="Numaralandır" Command="{Binding NumaralandirCommand}"
                    Style="{StaticResource AccentButton}" Visibility="Collapsed"/>

            <!-- Summary page: no bottom buttons -->
        </StackPanel>

        <!-- Progress & Status -->
        <StackPanel Grid.Row="3">
            <ProgressBar Margin="0,5,0,5" Value="{Binding Progress}" Minimum="0" Maximum="100"/>
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>
