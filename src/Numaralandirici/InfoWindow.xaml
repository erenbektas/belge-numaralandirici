<Window x:Class="Numaralandirici.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hakkında" Height="340" Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="icon.ico">

    <Grid Margin="25">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Icon -->
            <Image Source="icon.png" Width="72" Height="72" Margin="0,0,0,15"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- App name -->
            <TextBlock Text="Numaralandırıcı" FontSize="20" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>

            <!-- Version -->
            <TextBlock x:Name="TxtVersion" FontSize="13" Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <!-- Description -->
            <TextBlock Text="Belgeleri numaralandırıp tek bir PDF olarak birleştirir."
                       FontSize="12" Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                       Margin="0,0,0,18"/>

            <!-- GitHub link -->
            <TextBlock HorizontalAlignment="Center" Margin="0,0,0,18">
                <Hyperlink NavigateUri="https://github.com/erenbektas/belge-numaralandirici"
                           RequestNavigate="Hyperlink_RequestNavigate">
                    github.com/erenbektas/belge-numaralandirici
                </Hyperlink>
            </TextBlock>

            <!-- Author -->
            <TextBlock Text="Y. Eren Bektaş" FontSize="13"
                       HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
        </StackPanel>
    </Grid>
</Window>
